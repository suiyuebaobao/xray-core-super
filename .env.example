# ============================================================
# suiyue（岁月）环境变量配置
# ============================================================
# 复制此文件为 .env 并根据实际情况修改

# --- 数据库 ---
# Docker Compose 默认使用 mysql 服务名；本机直连开发可改为 127.0.0.1。
DATABASE_URL="suiyue_user:suiyue_password@tcp(mysql:3306)/suiyue?charset=utf8mb4&parseTime=True&loc=Local"
MIGRATE_DATABASE_URL="mysql://suiyue_user:suiyue_password@tcp(mysql:3306)/suiyue?charset=utf8mb4&parseTime=true&loc=Local"
MYSQL_PASSWORD="suiyue_password"
MYSQL_ROOT_PASSWORD="suiyue_root_password"

# --- 应用 ---
APP_PORT=3000
APP_BASE_URL="http://localhost:3000"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8080"
NGINX_HTTP_PORT=80

# --- JWT ---
JWT_SECRET="dev-local-secret-change-before-production-20260427"
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=168h

# --- 安全 ---
BCRYPT_ROUNDS=12
LOG_LEVEL=info

# --- 节点 Agent ---
AGENT_AUTH_MODE=token
AGENT_HEARTBEAT_INTERVAL=30s
XRAY_USER_KEY_DOMAIN=suiyue.local

# --- 兑换码 ---
REDEEM_CODE_LENGTH=16

# --- 订阅 ---
SUBSCRIPTION_TOKEN_TTL_DAYS=365
SUBSCRIPTION_PROFILE_NAME="RayPilot"

# --- 任务 ---
TASK_RETRY_LIMIT=10
TASK_LOCK_TTL=120s

# --- 支付（v1 保留骨架，暂不配置） ---
TRC20_ADDRESS=""
PAYMENT_CALLBACK_SECRET=""
PAYMENT_MIN_CONFIRMATIONS=20
ORDER_EXPIRE_DURATION=30m
